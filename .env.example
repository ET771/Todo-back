# Copia este archivo como .env y rellena los valores para tu entorno local.
# El archivo .env nunca se sube al repositorio (está en .gitignore).

# Base de datos MySQL
DB_USERNAME=root
DB_PASSWORD=tu_password_aqui
DB_URL=jdbc:mysql://localhost:3306/todogrupo2

# Ruta al JSON de credenciales de Firebase Admin SDK
# Descarga el archivo desde: Firebase Console > Configuracion del proyecto > Cuentas de servicio
FIREBASE_CREDENTIALS_PATH=src/main/resources/rutamx-44d01-firebase-adminsdk-fbsvc-abaa62722d.json
